---
# Prometheus Configuration
# Generated by Ansible for DevOps Coursework

global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}
  external_labels:
    environment: production
    project: devops-coursework

scrape_configs:
  # Prometheus itself
  - job_name: 'prometheus'
    static_configs:
      - targets:
          - 'localhost:{{ prometheus_port }}'
        labels:
          instance: 'prometheus'
          service: 'monitoring'

  # Node Exporter - All hosts (dynamic from inventory)
  - job_name: 'node_exporter'
    static_configs:
{% for host in groups['all'] %}
      - targets:
          - '{{ hostvars[host]["ansible_host"] | default(host) }}:9100'
        labels:
          instance: '{{ host }}'
          environment: 'production'
{% endfor %}

  # Nginx Exporter - Web servers only
  - job_name: 'nginx_exporter'
    static_configs:
{% for host in groups['webservers'] %}
      - targets:
          - '{{ hostvars[host]["ansible_host"] | default(host) }}:9113'
        labels:
          instance: '{{ host }}'
          service: 'nginx'
{% endfor %}