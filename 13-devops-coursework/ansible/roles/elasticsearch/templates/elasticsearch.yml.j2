# =============================================================================
# Elasticsearch Configuration - Version 9.x
# Generated by Ansible for DevOps Coursework
# Host: {{ inventory_hostname }}
# =============================================================================

# ------------------------ Cluster ---------------------------
cluster.name: {{ es_cluster_name }}

# ------------------------ Node ------------------------------
node.name: {{ es_node_name }}

# НОВОЕ В 9.x: используем node.roles вместо node.master и node.data
node.roles: [ master, data ]

# ------------------------ Paths -----------------------------
path.data: {{ es_path_data }}
path.logs: {{ es_path_logs }}

# ------------------------ Network ---------------------------
network.host: {{ es_network_host }}
http.port: {{ es_http_port }}
transport.port: {{ es_transport_port }}

# ------------------------ Discovery -------------------------
discovery.type: {{ es_discovery_type }}

# ------------------------ Security --------------------------
xpack.security.enabled: {{ es_xpack_security_enabled | lower }}
xpack.security.enrollment.enabled: {{ es_xpack_security_enrollment_enabled | lower }}
xpack.security.http.ssl.enabled: false
xpack.security.transport.ssl.enabled: false

# ------------------------ CORS (для Kibana) -----------------
http.cors.enabled: {{ es_cors_enabled | lower }}
http.cors.allow-origin: "{{ es_cors_allow_origin }}"
http.cors.allow-headers: X-Requested-With,Content-Type,Content-Length,Authorization
http.cors.allow-credentials: true

# ------------------------ Auto Create Index -----------------
action.auto_create_index: true