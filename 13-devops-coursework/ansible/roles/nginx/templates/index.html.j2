<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevOps Курсовая Работа | Дашборд</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-color: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.7);
            --card-border: rgba(255, 255, 255, 0.1);
            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --accent-green: #10b981;
            --accent-red: #ef4444;
            --accent-blue: #3b82f6;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --font-main: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: var(--font-main);
            background-color: var(--bg-color);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        /* --- Header --- */
        header {
            position: relative;
            padding: 4rem 1.5rem;
            text-align: center;
            overflow: hidden;
            background: #1e293b;
        }
        header::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background-image: url('https://image.qwenlm.ai/public_source/dba287b8-a620-402b-8f98-ae87d3f6fa48/1644c199c-35c0-4c0f-bd72-5eda26e46f53.png');
            background-size: cover;
            background-position: center;
            opacity: 0.4;
            z-index: 0;
        }
        header::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(to bottom, transparent, var(--bg-color));
            z-index: 1;
        }
        .header-content { position: relative; z-index: 2; max-width: 800px; margin: 0 auto; }
        h1 {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            background: linear-gradient(to right, #fff, #cbd5e1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 4px 12px rgba(0,0,0,0.3);
        }
        .subtitle { font-size: 1.1rem; color: var(--text-muted); font-weight: 300; letter-spacing: 0.5px; }
        .badge {
            display: inline-block;
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(4px);
            padding: 0.25rem 0.75rem;
            border-radius: 999px;
            font-size: 0.875rem;
            margin-top: 1rem;
            border: 1px solid rgba(255,255,255,0.1);
        }

        /* --- Layout --- */
        main {
            max-width: 1000px;
            margin: -3rem auto 2rem;
            padding: 0 1.5rem;
            position: relative;
            z-index: 10;
            display: grid;
            gap: 1.5rem;
            flex: 1;
        }

        /* --- Cards --- */
        .card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--card-border);
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.2);
            border-color: rgba(255,255,255,0.2);
        }
        .card-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding-bottom: 0.75rem;
        }
        .card-title {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-main);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .icon-box {
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent-blue);
        }

        /* --- Server Info --- */
        .server-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1rem;
        }
        .info-item { display: flex; flex-direction: column; gap: 0.25rem; }
        .info-label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; }
        .info-value {
            font-family: var(--font-mono);
            font-size: 0.95rem;
            color: var(--text-main);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .status-dot {
            width: 8px;
            height: 8px;
            background-color: var(--accent-green);
            border-radius: 50%;
            box-shadow: 0 0 8px var(--accent-green);
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(1.2); }
            100% { opacity: 1; transform: scale(1); }
        }

        /* --- Form Section --- */
        .form-container { display: flex; flex-direction: column; gap: 1.5rem; }
        .input-group { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }
        input[type="number"] {
            background: rgba(0,0,0,0.3);
            border: 1px solid var(--card-border);
            color: white;
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-family: var(--font-mono);
            font-size: 1rem;
            width: 120px;
            outline: none;
            transition: border-color 0.2s;
        }
        input[type="number"]:focus { border-color: var(--accent-blue); }
        .btn-submit {
            background: var(--primary-gradient);
            color: white;
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: opacity 0.2s, transform 0.1s;
        }
        .btn-submit:hover { opacity: 0.9; }
        .btn-submit:active { transform: scale(0.98); }
        .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-top: 0.5rem;
        }
        .stat-box { background: rgba(255,255,255,0.03); padding: 1rem; border-radius: 8px; }
        .stat-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
            color: var(--text-muted);
        }
        .progress-bg {
            height: 8px;
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
            overflow: hidden;
        }
        .progress-fill {
            height: 100%;
            background: var(--accent-blue);
            width: 0%;
            transition: width 0.3s ease;
            border-radius: 4px;
        }
        .progress-fill.success { background: var(--accent-green); }
        .progress-fill.error { background: var(--accent-red); }
        .summary-stats {
            display: flex;
            gap: 1.5rem;
            margin-top: 1rem;
            font-size: 0.9rem;
            color: var(--text-muted);
            border-top: 1px solid rgba(255,255,255,0.05);
            padding-top: 1rem;
        }
        .summary-item span { color: var(--text-main); font-weight: 600; }

        /* --- Quick Links --- */
        .links-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 1rem;
        }
        .link-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--card-border);
            color: var(--text-main);
            text-decoration: none;
            padding: 0.75rem;
            border-radius: 8px;
            font-size: 0.9rem;
            transition: all 0.2s;
            cursor: pointer;
        }
        .link-btn:hover {
            background: rgba(255,255,255,0.1);
            border-color: var(--accent-blue);
            transform: translateY(-2px);
        }
        .link-btn:active { transform: scale(0.98); }
        button.link-btn {
            font-family: var(--font-main);
            font-size: 0.9rem;
            color: var(--text-main);
            border: 1px solid var(--card-border);
            background: rgba(255,255,255,0.05);
            padding: 0.75rem;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            transition: all 0.2s;
        }
        button.link-btn:hover {
            background: rgba(255,255,255,0.1);
            border-color: var(--accent-blue);
            transform: translateY(-2px);
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: rgba(0,0,0,0.1); }
        ::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.2);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.3); }

        /* Responsive */
        @media (max-width: 640px) {
            h1 { font-size: 1.75rem; }
            .input-group { flex-direction: column; align-items: stretch; }
            .btn-submit { justify-content: center; }
            .summary-stats { flex-direction: column; gap: 0.5rem; }
        }
    </style>
</head>
<body>

    <header>
        <div class="header-content">
            <h1>Курсовая работа</h1>
            <div class="subtitle">по направлению "DevOps-инженер с нуля" - Спетницкий Д.И.</div>
            <div class="badge">Нетология | 2026</div>
        </div>
    </header>

    <main>
        <!-- Server Info Card -->
        <section class="card">
            <div class="card-header">
                <div class="icon-box">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
                </div>
                <h2 class="card-title">Информация о сервере</h2>
            </div>
            <div class="server-grid">
                <div class="info-item">
                    <span class="info-label">Hostname</span>
                    <span class="info-value" id="hostname">{{ inventory_hostname }}</span>
                </div>
                <div class="info-item">
                    <span class="info-label">IP Address</span>
                    <span class="info-value" id="ip-address">{{ ansible_default_ipv4.address | default('N/A') }}</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Zone</span>
                    <span class="info-value" id="zone">{{ yc_zone | default('unknown') }}</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Status</span>
                    <span class="info-value">
                        <div class="status-dot"></div> Online
                    </span>
                </div>
            </div>
        </section>

        <!-- Form Submission Card -->
        <section class="card">
            <div class="card-header">
                <div class="icon-box">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                </div>
                <h2 class="card-title">Отправка форм (Нагрузка)</h2>
            </div>

            <div class="form-container">
                <div class="input-group">
                    <div style="display:flex; align-items:center; gap:0.5rem; color:var(--text-muted);">
                        <span>Количество запросов:</span>
                    </div>
                    <input type="number" id="request-count" value="100" min="1" max="1000">
                    <button class="btn-submit" id="submit-btn" onclick="startLoadTest()">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        ОТПРАВИТЬ
                    </button>
                </div>

                <div class="stats-grid">
                    <div class="stat-box">
                        <div class="stat-header">
                            <span>web-a-1</span>
                            <span id="count-a">0</span>
                        </div>
                        <div class="progress-bg">
                            <div class="progress-fill" id="bar-a"></div>
                        </div>
                        <div style="text-align:right; font-size:0.75rem; margin-top:4px; color:var(--text-muted);" id="percent-a">0%</div>
                    </div>

                    <div class="stat-box">
                        <div class="stat-header">
                            <span>web-b-1</span>
                            <span id="count-b">0</span>
                        </div>
                        <div class="progress-bg">
                            <div class="progress-fill" id="bar-b"></div>
                        </div>
                        <div style="text-align:right; font-size:0.75rem; margin-top:4px; color:var(--text-muted);" id="percent-b">0%</div>
                    </div>
                </div>

                <div class="summary-stats">
                    <div class="summary-item">Отправлено: <span id="total-sent">0</span> / <span id="total-target">0</span></div>
                    <div class="summary-item" style="color:var(--accent-green)">Успешно: <span id="total-success">0</span></div>
                    <div class="summary-item" style="color:var(--accent-red)">Ошибок: <span id="total-errors">0</span></div>
                </div>
            </div>
        </section>

        <!-- Quick Links Card -->
        <section class="card">
            <div class="card-header">
                <div class="icon-box">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                </div>
                <h2 class="card-title">Быстрые ссылки</h2>
            </div>
            <div class="links-grid">
                <a href="http://{{ grafana_public_ip }}:3000" target="_blank" class="link-btn">
                    <svg width="18" height="18" fill="orange" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                    Grafana
                </a>
                <a href="http://{{ kibana_public_ip }}:5601" target="_blank" class="link-btn">
                    <svg width="18" height="18" fill="#005571" viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/></svg>
                    Kibana
                </a>
                <button onclick="checkLoadBalancing()" class="link-btn">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    Балансировка
                </button>
            </div>
        </section>
    </main>

    <script>
        // --- Configuration ---
        const API_SUBMIT = '/api/submit.php';

        // --- State ---
        let isRunning = false;
        let stats = {
            total: 0,
            success: 0,
            error: 0,
            servers: {}
        };

        // --- Mapping: full hostname → short key for DOM elements ---
        function getServerKey(fullHostname) {
            const short = fullHostname.replace('devops-coursework-', '');
            if (short === 'web-a-1') return 'a';
            if (short === 'web-b-1') return 'b';
            return null;
        }

        // --- Load Test Functions ---
        async function startLoadTest() {
            if (isRunning) return;

            const countInput = document.getElementById('request-count');
            const count = parseInt(countInput.value) || 100;
            const btn = document.getElementById('submit-btn');

            isRunning = true;
            btn.disabled = true;
            btn.innerHTML = `<svg class="animate-spin" width="16" height="16" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> ОТПРАВКА...`;

            stats = { total: 0, success: 0, error: 0, servers: {} };
            updateStatsUI(count);

            const batchSize = 10;
            let sent = 0;

            const processBatch = async () => {
                if (sent >= count) { finishLoadTest(); return; }
                const promises = [];
                for (let i = 0; i < batchSize && sent < count; i++) {
                    promises.push(sendSingleRequest());
                    sent++;
                }
                await Promise.all(promises);
                setTimeout(processBatch, 50);
            };
            processBatch();
        }

        async function sendSingleRequest() {
            try {
                const res = await fetch(API_SUBMIT, { method: 'POST' });
                const fullHostname = res.headers.get('X-Served-By') || 'unknown';
                const serverKey = getServerKey(fullHostname);

                if (res.ok && serverKey) {
                    stats.success++;
                    if (!stats.servers[serverKey]) {
                        stats.servers[serverKey] = 0;
                    }
                    stats.servers[serverKey]++;
                } else {
                    stats.error++;
                }
                stats.total++;
                updateStatsUI(parseInt(document.getElementById('request-count').value));
            } catch (e) {
                stats.error++;
                stats.total++;
                updateStatsUI(parseInt(document.getElementById('request-count').value));
            }
        }

        function finishLoadTest() {
            isRunning = false;
            const btn = document.getElementById('submit-btn');
            btn.disabled = false;
            btn.innerHTML = `▶️ ОТПРАВИТЬ`;
        }

        // --- UI Updates ---
        function updateStatsUI(totalTarget) {
            document.getElementById('total-sent').innerText = stats.total;
            document.getElementById('total-target').innerText = totalTarget;
            document.getElementById('total-success').innerText = stats.success;
            document.getElementById('total-errors').innerText = stats.error;

            ['a', 'b'].forEach(key => {
                const count = stats.servers[key] || 0;
                const percent = totalTarget > 0 ? ((count / totalTarget) * 100).toFixed(1) : 0;

                const countEl = document.getElementById(`count-${key}`);
                const barEl = document.getElementById(`bar-${key}`);
                const percentEl = document.getElementById(`percent-${key}`);

                if (countEl) countEl.innerText = count;
                if (barEl) barEl.style.width = `${percent}%`;
                if (percentEl) percentEl.innerText = `${percent}%`;
            });
        }

        async function checkLoadBalancing() {
            const results = [];
            const count = 13;

            for (let i = 0; i < count; i++) {
                try {
                    const res = await fetch('/api/whoami.php');
                    const data = await res.json();
                    results.push(data.hostname.replace('devops-coursework-', ''));
                } catch (e) {
                    results.push('error');
                }
            }

            const distribution = {};
            results.forEach(h => {
                distribution[h] = (distribution[h] || 0) + 1;
            });

            const message = Object.entries(distribution)
                .map(([host, hostCount]) => `${host}: ${hostCount} (${((hostCount/count)*100).toFixed(1)}%)`)
                .join('\n');

            alert(`🔄 Распределение за ${count} запросов:\n\n${message}`);
        }
    </script>
</body>
</html>