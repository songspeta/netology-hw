# =============================================================================
# Filebeat Configuration - Bastion Host (bastion-a-1)
# =============================================================================

filebeat.config.modules:
  path: ${path.config}/modules.d/*.yml
  reload.enabled: false

filebeat.inputs:
  # =========================================================================
  # SYSLOG
  # =========================================================================
  - type: filestream
    enabled: true
    id: syslog
    paths:
      - /var/log/syslog
    prospector.scanner.fingerprint.enabled: false
    file_identity:
      native: ~
    prospector.scanner.fingerprint.length: 1
    fields:
      service: syslog
      environment: production
      host: {{ inventory_hostname }}
    fields_under_root: false

  # =========================================================================
  # AUTH LOG
  # =========================================================================
  - type: filestream
    enabled: true
    id: auth
    paths:
      - /var/log/auth.log
    prospector.scanner.fingerprint.enabled: false
    file_identity:
      native: ~
    prospector.scanner.fingerprint.length: 1
    fields:
      service: auth
      environment: production
      host: {{ inventory_hostname }}
    fields_under_root: false

# =============================================================================
# OUTPUT
# =============================================================================
output.elasticsearch:
  hosts:
    - "http://{{ hostvars['elasticsearch-b-1']['ansible_host'] }}:9200"
  index: "filebeat-%{[fields.service]}-%{+yyyy.MM.dd}"

# =============================================================================
# НАСТРОЙКИ ШАБЛОНА И ILM
# =============================================================================
setup.ilm.enabled: false
setup.template.enabled: false
setup.template.name: "filebeat"
setup.template.pattern: "filebeat-*"

# =============================================================================
# PROCESSORS
# =============================================================================
processors:
  - add_host_metadata:
      when.not.contains.tags: forwarded
  - add_cloud_metadata: ~

# =============================================================================
# LOGGING
# =============================================================================
logging.level: warning
logging.to_files: true
logging.files:
  path: /var/log/filebeat
  name: filebeat
  keepfiles: 7
  permissions: 0644

# =============================================================================
# MONITORING
# =============================================================================
http.enabled: false