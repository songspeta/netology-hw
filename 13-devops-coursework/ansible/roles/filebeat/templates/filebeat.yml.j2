# =============================================================================
# Filebeat Configuration - Version {{ filebeat_version | default('9.3.2') }}
# Generated by Ansible for DevOps Coursework
# Host: {{ inventory_hostname }}
# =============================================================================

# ------------------------ Filebeat Config ---------------------
filebeat.config.modules:
  path: ${path.config}/modules.d/*.yml
  reload.enabled: false

# ------------------------ Filestream Inputs (Filebeat 9.x) ----
filebeat.inputs:
  # Application submissions log
  - type: filestream
    enabled: true
    id: web-submissions
    paths:
      - /var/log/submissions.log

    prospector.scanner.fingerprint.enabled: false

    file_identity:
      native: ~

    fields:
      service: web-submissions
      environment: production
      host: {{ inventory_hostname }}
    fields_under_root: true

    multiline.pattern: '^\d{4}-\d{2}-\d{2}'
    multiline.match: after
    multiline.negate: false

  # Nginx access log
  - type: filestream
    enabled: true
    id: nginx-access
    paths:
      - /var/log/nginx/access.log

    prospector.scanner.fingerprint.enabled: false
    file_identity:
      native: ~
    fields:
      service: nginx-access
      environment: production
      host: {{ inventory_hostname }}
    fields_under_root: true

  # Nginx error log
  - type: filestream
    enabled: true
    id: nginx-error
    paths:
      - /var/log/nginx/error.log

    prospector.scanner.fingerprint.enabled: false
    file_identity:
      native: ~
    fields:
      service: nginx-error
      environment: production
      host: {{ inventory_hostname }}
    fields_under_root: true

    # Elasticsearch-logs
  - type: filestream
    enabled: true
    id: elasticsearch-logs
    paths:
      - /var/log/elasticsearch/devops-coursework.log
      - /var/log/elasticsearch/gc.log
    prospector.scanner.fingerprint.enabled: false
    file_identity:
      native: ~
    fields:
      service: elasticsearch
      environment: production
      host: {{ inventory_hostname }}
    fields_under_root: true

  # Kibana logs
  - type: filestream
    enabled: true
    id: kibana-logs
    paths:
      - /var/log/kibana/kibana.log
    prospector.scanner.fingerprint.enabled: false
    file_identity:
      native: ~
    fields:
      service: kibana
      environment: production
      host: {{ inventory_hostname }}
    fields_under_root: true

  # Prometheus logs
  - type: filestream
    enabled: true
    id: prometheus-logs
    paths:
      - /var/log/prometheus/prometheus.log
    prospector.scanner.fingerprint.enabled: false
    file_identity:
      native: ~
    fields:
      service: prometheus
      environment: production
      host: {{ inventory_hostname }}
    fields_under_root: true

  # Grafana logs
  - type: filestream
    enabled: true
    id: grafana-logs
    paths:
      - /var/log/grafana/grafana.log
    prospector.scanner.fingerprint.enabled: false
    file_identity:
      native: ~
    fields:
      service: grafana
      environment: production
      host: {{ inventory_hostname }}
    fields_under_root: true


# ------------------------ Elasticsearch Output ------------------
output.elasticsearch:
  hosts:
    - "http://{{ hostvars['elasticsearch']['ansible_host'] }}:9200"

  index: "applogs-%{+yyyy.MM.dd}"

# ------------------------ Настройки шаблона (глобальные) -----
setup.ilm.enabled: false
setup.template.enabled: false
setup.template.name: "applogs"
setup.template.pattern: "applogs-*"
setup.template.overwrite: false

# ------------------------ Processors ----------------------------
processors:
  - add_host_metadata:
      when.not.contains.tags: forwarded
  - add_cloud_metadata: ~

# ------------------------ Logging -------------------------------
logging.level: {{ filebeat_logging_level | default('warning') }}
logging.to_files: true
logging.files:
  path: /var/log/filebeat
  name: filebeat
  keepfiles: {{ filebeat_logging_keepfiles | default(7) }}
  permissions: 0644

# ------------------------ Monitoring ----------------------------
http.enabled: false