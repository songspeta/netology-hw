{
  "_meta": {
    "description": "Data Views for DevOps Coursework - Generated by Ansible",
    "version": "9.3.2"
  },
  "data_views": [
    {% for view in kibana_data_views %}
    {
      "id": "{{ view.id }}",
      "type": "index-pattern",
      "attributes": {
        "title": "{{ view.title }}",
        "timeFieldName": "{{ view.time_field }}",
        "description": "{{ view.description | default('') }}",
        "sourceFilters": "[]",
        "fieldAttrs": "{}",
        "fields": "[]",
        "runtimeFieldMap": "{}"
      },
      "references": []
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}