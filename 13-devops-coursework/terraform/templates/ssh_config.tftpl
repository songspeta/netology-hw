# =============================================================================
# SSH Config - DevOps Coursework
# Auto-generated by Terraform
# DO NOT EDIT MANUALLY - Regenerated on terraform apply
# =============================================================================

# -----------------------------------------------------------------------------
# Global Settings (for all hosts in this project)
# -----------------------------------------------------------------------------
Host *
    User ubuntu
    IdentityFile ~/.ssh/terr
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
    LogLevel ERROR
    ServerAliveInterval 60
    ServerAliveCountMax 3

# -----------------------------------------------------------------------------
# Bastion Host (direct connection)
# -----------------------------------------------------------------------------
Host bastion-a-1
    HostName ${bastion_ip}
    User ubuntu
    IdentityFile ~/.ssh/terr

# -----------------------------------------------------------------------------
# Web Servers (through Bastion)
# -----------------------------------------------------------------------------
Host web-a-1
    HostName ${web_a_ip}
    User ubuntu
    IdentityFile ~/.ssh/terr
    ProxyJump bastion-a-1

Host web-b-1
    HostName ${web_b_ip}
    User ubuntu
    IdentityFile ~/.ssh/terr
    ProxyJump bastion-a-1

# -----------------------------------------------------------------------------
# Elasticsearch (through Bastion)
# -----------------------------------------------------------------------------
Host elasticsearch-b-1
    HostName ${elasticsearch_ip}
    User ubuntu
    IdentityFile ~/.ssh/terr
    ProxyJump bastion-a-1

# -----------------------------------------------------------------------------
# Kibana (through Bastion)
# -----------------------------------------------------------------------------
Host kibana-b-1
    HostName ${kibana_ip}
    User ubuntu
    IdentityFile ~/.ssh/terr
    ProxyJump bastion-a-1

# -----------------------------------------------------------------------------
# Prometheus (through Bastion)
# -----------------------------------------------------------------------------
Host prometheus-a-1
    HostName ${prometheus_ip}
    User ubuntu
    IdentityFile ~/.ssh/terr
    ProxyJump bastion-a-1

# -----------------------------------------------------------------------------
# Grafana (through Bastion)
# -----------------------------------------------------------------------------
Host grafana-a-1
    HostName ${grafana_ip}
    User ubuntu
    IdentityFile ~/.ssh/terr
    ProxyJump bastion-a-1