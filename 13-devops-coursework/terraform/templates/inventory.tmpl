# === Ansible Inventory (Generated by Terraform) ===

[all:vars]
ansible_user=ubuntu
ansible_ssh_private_key_file=~/.ssh/id_ed25519
ansible_python_interpreter=/usr/bin/python3
ansible_ssh_common_args='-o ProxyCommand="ssh -W %h:%p -q ubuntu@${bastion_ip}"'

[bastion]
bastion ansible_host=${bastion_ip}

[web_servers]
%{for i, ip in split(",", web_ips)}web-${i + 1} ansible_host=${ip}
%{endfor}

[monitoring_servers]
prometheus ansible_host=${prometheus_ip}
grafana ansible_host=${grafana_ip}

[logging_servers]
elasticsearch ansible_host=${elasticsearch_ip}
kibana ansible_host=${kibana_ip}

[nginx:children]
web_servers

[exporters:children]
web_servers

[prometheus_scrape_targets:children]
web_servers
monitoring_servers