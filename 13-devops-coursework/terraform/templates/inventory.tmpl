# =============================================================================
# ANSIBLE INVENTORY - Auto-generated by Terraform
# =============================================================================
# DO NOT EDIT MANUALLY - Changes will be overwritten!
# =============================================================================

[all:vars]
ansible_user=${ssh_user}
ansible_ssh_private_key_file=~/.ssh/terr
ansible_python_interpreter=/usr/bin/python3

# Public IPs для ссылок
grafana_public_ip=${grafana_public_ip}
kibana_public_ip=${kibana_public_ip}

# =============================================================================
# BASTION HOST
# =============================================================================
[bastion]
bastion-a-1 ansible_host=${bastion_public_ip} private_ip=${bastion_private_ip}

# =============================================================================
# WEB SERVERS (Nginx)
# =============================================================================
[webservers]
web-a-1 ansible_host=${web_a_private_ip} yc_zone=${web_a_zone} private_ip=${web_a_private_ip}
web-b-1 ansible_host=${web_b_private_ip} yc_zone=${web_b_zone} private_ip=${web_b_private_ip}

[webservers:vars]
ansible_ssh_common_args='-o ProxyJump=${ssh_user}@${bastion_public_ip}'

# =============================================================================
# PROMETHEUS
# =============================================================================
[prometheus]
prometheus-a-1 ansible_host=${prometheus_private_ip} ansible_ssh_common_args='-o ProxyJump=${ssh_user}@${bastion_public_ip}' private_ip=${prometheus_private_ip}

# =============================================================================
# GRAFANA
# =============================================================================
[grafana]
grafana-a-1 ansible_host=${grafana_private_ip} ansible_ssh_common_args='-o ProxyJump=${ssh_user}@${bastion_public_ip}' private_ip=${grafana_private_ip}

# =============================================================================
# ELASTICSEARCH
# =============================================================================
[elasticsearch]
elasticsearch-b-1 ansible_host=${elasticsearch_private_ip} ansible_ssh_common_args='-o ProxyJump=${ssh_user}@${bastion_public_ip}' private_ip=${elasticsearch_private_ip}

# =============================================================================
# KIBANA
# =============================================================================
[kibana]
kibana-b-1 ansible_host=${kibana_private_ip} ansible_ssh_common_args='-o ProxyJump=${ssh_user}@${bastion_public_ip}' private_ip=${kibana_private_ip}

# =============================================================================
# ALL PRIVATE HOSTS (через Bastion)
# =============================================================================
[private_hosts:children]
webservers
prometheus
grafana
elasticsearch
kibana

# =============================================================================
# ALL PUBLIC HOSTS (прямой доступ)
# =============================================================================
[public_hosts]
bastion-a-1