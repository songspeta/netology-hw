# =============================================================================
# ANSIBLE INVENTORY - Auto-generated by Terraform
# =============================================================================
# DO NOT EDIT MANUALLY - Changes will be overwritten!
# Generated: ${timestamp()}
# =============================================================================

[all:vars]
ansible_user=${ssh_user}
ansible_ssh_private_key_file=~/.ssh/terr
ansible_python_interpreter=/usr/bin/python3

# Public IPs для ссылок
grafana_public_ip=${grafana_public_ip}
kibana_public_ip=${kibana_public_ip}
alb_public_ip=${alb_public_ip}

# =============================================================================
# BASTION HOST
# =============================================================================
[bastion]
bastion ansible_host=${bastion_public_ip}

# =============================================================================
# WEB SERVERS (Nginx)
# =============================================================================
[webservers]
web-a-1 ansible_host=${web_a_private_ip} yc_zone=${web_a_zone}
web-b-1 ansible_host=${web_b_private_ip} yc_zone=${web_b_zone}

[webservers:vars]
ansible_ssh_common_args='-o ProxyJump=${ssh_user}@${bastion_public_ip}'

# =============================================================================
# MONITORING (Prometheus + Grafana)
# =============================================================================
[monitoring]
prometheus ansible_host=${prometheus_private_ip} ansible_ssh_common_args='-o ProxyJump=${ssh_user}@${bastion_public_ip}'
grafana ansible_host=${grafana_private_ip} ansible_ssh_common_args='-o ProxyJump=${ssh_user}@${bastion_public_ip}'

# =============================================================================
# LOGGING (Elasticsearch + Kibana)
# =============================================================================
[logging]
elasticsearch ansible_host=${elasticsearch_private_ip} ansible_ssh_common_args='-o ProxyJump=${ssh_user}@${bastion_public_ip}'
kibana ansible_host=${kibana_private_ip} ansible_ssh_common_args='-o ProxyJump=${ssh_user}@${bastion_public_ip}'

# =============================================================================
# ALL PRIVATE HOSTS (через Bastion)
# =============================================================================
[private_hosts:children]
webservers
monitoring
logging

# =============================================================================
# ALL PUBLIC HOSTS (прямой доступ)
# =============================================================================
[public_hosts]
bastion